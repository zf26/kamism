# ─── 数据库 ──────────────────────────────────────────
# PostgreSQL 密码（自动创建 kamism 数据库和用户）请不要包含特殊字符
POSTGRES_PASSWORD=change_me_strong_password

# ─── RabbitMQ ────────────────────────────────────────
#  请不要包含特殊字符
RABBITMQ_PASSWORD=change_me_rabbitmq_password

# ─── 认证 ────────────────────────────────────────────
# JWT 签名密钥（建议 32 位以上随机字符串）
JWT_SECRET=change_me_jwt_secret_at_least_32_chars
# 加密密钥
MASTER_KEY=十六进制字符串（64 个字符）
# Oauth2 授权后回调地址（开启oauth2认证时填写,默认为http://localhost:1420）
FRONTEND_URL=http://localhost:1420

# ─── 管理员账号（首次启动自动创建）────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456

# ─── 端口（可选）─────────────────────────────────────
# 前端访问端口（默认 1420），后端不对外暴露
FRONTEND_PORT=1420

# ─── 邮件服务（可选，不填则禁用邮件功能）──────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=KamiSM
SMTP_FROM_EMAIL=noreply@example.com

# ─── 支付通道 ──────────────────────────────────────────
# 支持 xorpay 和 mbdpay（0 手续费，推荐），默认 mbdpay
PAY_CHANNEL=mbdpay

# MbdPay（https://p.mbd.pub 申请）
MBD_APP_ID=
MBD_APP_KEY=
MBD_NOTIFY_URL=https://yourdomain.com/api/pay/notify

# XorPay（https://xorpay.com 申请）
XORPAY_AID=
XORPAY_APP_KEY=
XORPAY_NOTIFY_URL=https://yourdomain.com/api/pay/notify

# ─── 日志级别 ─────────────────────────────────────────
# 可选: error, warn, info, debug, trace
RUST_LOG=info
