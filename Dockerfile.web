# 前端静态文件构建 + Nginx 服务
FROM node:20-alpine AS builder

WORKDIR /app

# [1/3] 安装前端依赖
RUN echo "==> [1/3] 复制 package.json，准备安装依赖..."
COPY package.json package-lock.json ./
RUN echo "==> [1/3] 安装 npm 依赖（首次约需 1~3 分钟）..." \
    && npm ci \
    && echo "==> [1/3] npm 依赖安装完成"

# [2/3] 复制源码并构建
RUN echo "==> [2/3] 复制前端源码..."
COPY index.html tsconfig.json tsconfig.node.json vite.config.ts ./
COPY src ./src
COPY public ./public

# 构建时注入后端 API 地址（用户在 .env 中配置 VITE_API_URL）
ARG VITE_API_URL=http://localhost:9527
ENV VITE_API_URL=$VITE_API_URL

RUN echo "==> [2/3] 构建前端静态文件（API 地址: ${VITE_API_URL}）..." \
    && npm run build \
    && echo "==> [2/3] 前端构建完成"

# ─── Nginx 服务阶段 ───────────────────────────────────
FROM nginx:alpine

# [3/3] 部署到 Nginx
RUN echo "==> [3/3] 部署前端文件到 Nginx..."
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
